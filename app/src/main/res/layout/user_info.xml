<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:padding="16dp">

    <ImageButton
        android:id="@+id/backButton"
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:layout_alignParentStart="true"
        android:layout_alignParentTop="true"
        android:layout_marginStart="18dp"
        android:layout_marginTop="101dp"
        android:background="@android:color/transparent"
        android:scaleType="centerInside"
        android:src="@drawable/ic_back" />

    <TextView
        android:id="@+id/userInfoTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="100dp"
        android:layout_marginBottom="30dp"
        android:fontFamily="sans-serif"
        android:gravity="center"
        android:text="User Informations"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold" />

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="389dp"
        android:layout_height="567dp"
        android:layout_below="@id/userInfoTitle"
        android:layout_marginTop="2dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="16dp"
            android:background="@drawable/bg_cart1"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Profile Image -->
            <FrameLayout
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_marginBottom="24dp"
                android:background="@drawable/circle_shape"
                android:clipToOutline="true"
                android:outlineProvider="background">

                <ImageView
                    android:id="@+id/profileImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/user1" />
            </FrameLayout>

            <!-- Username -->
            <TextView
                android:id="@+id/usernameText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="start"
                android:layout_marginBottom="12dp"
                android:fontFamily="sans-serif"
                android:gravity="start"
                android:text="Username: S.A.P.Diva"
                android:textColor="#FFFFFF"
                android:textSize="18sp" />

            <!-- Email -->
            <TextView
                android:id="@+id/emailText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="start"
                android:layout_marginBottom="24dp"
                android:fontFamily="sans-serif"
                android:gravity="start"
                android:text="Email: 2022t01564@stu.lk"
                android:textColor="#FFFFFF"
                android:textSize="18sp" />

            <!-- Edit Info Button -->

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/editInfoButton"
                android:layout_width="230dp"
                android:layout_height="46dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/edit_info_button"
                android:text="Edit Info"
                android:textAllCaps="false"
                android:textColor="#000000"
                android:textSize="18sp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/exitButton"
                android:layout_width="230dp"
                android:layout_height="46dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/exit_button_rounded"
                android:text="Sign Up"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="18sp" />
        </LinearLayout>
    </ScrollView>

    <!-- Sign Out Button OUTSIDE the user info area -->

</RelativeLayout>
