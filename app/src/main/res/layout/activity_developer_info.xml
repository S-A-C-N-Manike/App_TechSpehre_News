<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:padding="16dp">

    <!-- Header Title -->
    <TextView
        android:id="@+id/headerTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="75dp"
        android:layout_marginBottom="50dp"
        android:gravity="center"
        android:text="Developer Information"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold" />

    <!-- Scrollable Content -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_below="@id/headerTitle"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="20dp">




        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center_horizontal"
            android:background="@drawable/bg_card"
            android:layout_margin="16dp">

            <!-- Developer Photo in Circular Frame -->
            <FrameLayout
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:layout_marginBottom="20dp"
                android:background="@drawable/circle_shape"
                android:clipToOutline="true"
                android:outlineProvider="background">

                <ImageView
                    android:id="@+id/developerPhoto"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/profile_pic" />
            </FrameLayout>

            <!-- Developer Info Text -->
            <TextView
                android:id="@+id/devInfoText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Name: Chalani Nethranjali\n\nStudent ID: 2022T01553\n\nPersonal Statement: Student\n\nReleased Version: V1.0.0"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:lineSpacingExtra="6dp"
                android:layout_marginBottom="30dp" />

            <!-- Contact Info Section -->


            <!-- Exit Button -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/exitButton"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Exit"
                android:textAllCaps="false"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="@drawable/exit_button_rounded" />
        </LinearLayout>
    </ScrollView>
</RelativeLayout>
