<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="368dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@android:color/white"
    android:padding="20dp"
    android:layout_gravity="center"
    android:elevation="8dp"
    android:clipToPadding="false"
    android:backgroundTint="#FFFFFF"
    android:layout_margin="16dp">

    <!-- Header -->
    <TextView
        android:id="@+id/editHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Edit User Information"
        android:textColor="#000000"
        android:textSize="20sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="16dp" />

    <!-- Username Field with Icon -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:layout_marginBottom="12dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_centerVertical="true"
            android:layout_marginStart="12dp"
            android:src="@drawable/usericon" />

        <EditText
            android:id="@+id/editUsername"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_toEndOf="@null"
            android:layout_marginStart="45dp"
            android:hint="Username"
            android:textColor="#000000"
            android:textSize="16sp"
            android:background="@drawable/edit_field_background"
            android:paddingStart="16dp"
            android:drawablePadding="10dp" />
    </RelativeLayout>

    <!-- Email Field with Icon -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="65dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_centerVertical="true"
            android:layout_marginStart="12dp"
            android:src="@drawable/emailicon" />

        <EditText
            android:id="@+id/editEmail"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginStart="45dp"
            android:hint="Email"
            android:textColor="#000000"
            android:textSize="16sp"
            android:background="@drawable/edit_field_background"
            android:paddingStart="16dp"
            android:drawablePadding="10dp" />
    </RelativeLayout>

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:orientation="horizontal"
        android:gravity="center">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnConfirmEdit"
            android:layout_width="112dp"
            android:layout_height="49dp"
            android:text="Ok"
            android:textAllCaps="false"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#120A8F"
            android:background="@drawable/blue_button_rounded"
            android:layout_marginEnd="8dp" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnCancelEdit"
            android:layout_width="112dp"
            android:layout_height="49dp"
            android:text="Cancel"
            android:textAllCaps="false"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#DA0004"
            android:background="@drawable/red_button_rounded" />
    </LinearLayout>
</LinearLayout>
