<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bggradient">

    <!-- Background Rectangle Layer -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#B2D3FE"
        android:layout_marginBottom="0dp"
        android:layout_marginTop="412dp"
        android:layout_gravity="bottom"
        android:backgroundTint="#B2D3FE"
        android:clipToOutline="true" />

    <!-- Foreground content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:padding="32dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <!-- Logo -->

            <!-- Slogan -->
            <ImageView
                android:id="@+id/logoImage"
                android:layout_width="285dp"
                android:layout_height="241dp"
                android:layout_marginBottom="50dp"
                android:src="@drawable/logo" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Your digital connection\nto the university starts here"
                android:textColor="#FFFFFF"
                android:textAlignment="center"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="100dp" />

            <!-- Username Field -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/edit_text_bg"
                android:padding="12dp"
                android:layout_marginBottom="16dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/usericon"
                    android:layout_gravity="center_vertical"
                    android:layout_marginEnd="8dp" />

                <EditText
                    android:id="@+id/usernameEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Username"
                    android:textColor="#000000"
                    android:textSize="16sp"
                    android:background="@android:color/transparent"
                    android:inputType="text" />
            </LinearLayout>

            <!-- Password Field -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/edit_text_bg"
                android:padding="12dp"
                android:layout_marginBottom="60dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/lockiconn"
                    android:layout_gravity="center_vertical"
                    android:layout_marginEnd="8dp" />

                <EditText
                    android:id="@+id/passwordEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Password"
                    android:textColor="#000000"
                    android:textSize="16sp"
                    android:inputType="textPassword"
                    android:background="@android:color/transparent" />
            </LinearLayout>

            <!-- Login Button -->
            <Button
                android:id="@+id/loginButton"
                android:layout_width="300dp"
                android:layout_height="75dp"
                android:text="Login"
                android:textColor="#FFFFFF"
                android:textSize="25sp"
                android:background="@drawable/login_button_bg"
                android:layout_marginBottom="55dp" />

            <!-- Sign-up Prompt -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Don’t have an account?"
                android:textColor="#000000"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/signupLink"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sign up"
                android:textColor="#050E76"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginBottom="16dp" />

            <!-- Legal Terms -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="By clicking continue, you agree to our Terms of Service\nand Privacy Policy"
                android:textAlignment="center"
                android:textColor="#000000"
                android:textSize="12sp" />
        </LinearLayout>
    </ScrollView>
</FrameLayout>